{
	"helix_mode": true,
 "base_keymap": "VSCode",
 "minimap": {
  "thumb": "always",
  "show": "never"
 },
 "tabs": {
		"git_status": true
	},
	"title_bar": {
		"show_menus": false
	},
	"icon_theme": "Material Icon Theme",
	"edit_predictions": {
		"mode": "eager",
		"disabled_globs": [
			"**/.env*",
			"**/*.pem",
			"**/*.key",
			"**/*.cert",
			"**/*.crt",
			"**/secrets.yml"
		]
	},
